{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "strict": true,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "importHelpers": true
  },
  "include": ["src/**/*.ts"]
}
